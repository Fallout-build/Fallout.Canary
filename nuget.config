<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="fallout-github" value="https://nuget.pkg.github.com/Fallout-build/index.json" protocolVersion="3" />
  </packageSources>

  <!-- The Fallout.* packages and the Nuke.* transition shims live ONLY on the
       Fallout-build GitHub Packages feed (never nuget.org). Everything else
       (BCL, etc.) comes from nuget.org. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="fallout-github">
      <package pattern="Fallout.*" />
      <package pattern="Nuke.*" />
      <package pattern="fallout.globaltools" />
    </packageSource>
  </packageSourceMapping>

  <!-- Credentials for the GitHub Packages feed. NuGet expands %FALLOUT_PACKAGES_TOKEN%
       from the environment at restore time. CI provides it from the repo secret of the
       same name; locally, export it (a PAT with read:packages on Fallout-build).
       The username is not validated for reads — any non-empty value works. -->
  <packageSourceCredentials>
    <fallout-github>
      <add key="Username" value="Fallout-build" />
      <add key="ClearTextPassword" value="%FALLOUT_PACKAGES_TOKEN%" />
    </fallout-github>
  </packageSourceCredentials>
</configuration>
