<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace></RootNamespace>
    <NoWarn>CS0649;CS0169;CA1050;CA1822;CA2211;IDE1006</NoWarn>
    <FalloutRootDirectory>..</FalloutRootDirectory>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Mid-migration consumer: references ONLY the legacy Nuke.Common shim package,
         not Fallout.Common. Tests that the shim package (which depends on Fallout.Common
         and must flow its source generator) lets a classic `class Build : NukeBuild`
         compile and run. Floated to the latest published -preview. -->
    <PackageReference Include="Nuke.Common" Version="2026.1.*-*" />
  </ItemGroup>

</Project>
