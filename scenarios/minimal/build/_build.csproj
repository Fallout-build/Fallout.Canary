<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace></RootNamespace>
    <NoWarn>CS0649;CS0169;CA1050;CA1822;CA2211;IDE1006</NoWarn>
    <!-- Scenario root = scenarios/minimal (one up from build/). -->
    <FalloutRootDirectory>..</FalloutRootDirectory>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Floated to the latest published -preview from the Fallout-build GitHub Packages
         feed. This is the package under test. The package is expected to bring its
         source generators (as an analyzer) and build props/targets transitively. -->
    <PackageReference Include="Fallout.Common" Version="2026.1.*-*" />
  </ItemGroup>

</Project>
